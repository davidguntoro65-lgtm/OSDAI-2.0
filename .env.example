# =============================================================
# OSDAI — Otomatisasi Sekolah Digital Berbasis AI
# Environment Configuration Template
# Copy this file to .env and fill in the values.
# =============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
APP_NAME="OSDAI"
APP_ENV=development
# Full URL of the app (no trailing slash). Auto-detected if blank.
APP_URL=
APP_PORT=5000

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/osdai

# ------------------------------------------------------------
# AUTHENTICATION
# ------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_64_chars

# ------------------------------------------------------------
# AI INTEGRATION (Replit-managed — leave blank on Replit)
# Set GEMINI_API_KEY only when running outside Replit.
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# EMAIL / OTP
# Choose: smtp | resend
# ------------------------------------------------------------
EMAIL_PROVIDER=smtp

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Resend (alternative to SMTP)
RESEND_API_KEY=

# ------------------------------------------------------------
# PAYMENT — Midtrans
# ------------------------------------------------------------
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ------------------------------------------------------------
# REDIS (optional — used for caching/queues)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# FILE STORAGE
# Leave STORAGE_PROVIDER=local for filesystem uploads.
# Set to "cloudinary" and fill keys for cloud storage.
# ------------------------------------------------------------
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------
# QR / REPORTS
# ------------------------------------------------------------
QR_SECRET=change_me_qr_secret

# ------------------------------------------------------------
# MAPS (GPS attendance)
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------
# REALTIME (Socket.IO — built-in, no external needed)
# Pusher keys only if you want to migrate to Pusher later.
# ------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
CORS_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs
